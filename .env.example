# Copy to .env and adjust. All app settings use the LEADGEN_ prefix;
# OLLAMA_BASE_URL is read without a prefix.

# --- Search ---
LEADGEN_LOCATION=Boston, MA
# Backend: 'overpass' (OpenStreetMap, real businesses), 'duckduckgo' (web
# search), or 'google' (often JS-blocked now).
LEADGEN_SEARCH_BACKEND=overpass
LEADGEN_RESULTS_PER_CATEGORY=10
LEADGEN_SEARCH_DELAY_SECONDS=2.5

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
LEADGEN_OLLAMA_MODEL=llama3.2
LEADGEN_OLLAMA_FALLBACK_MODEL=llama3.1

# --- Sender identity (used to personalize emails) ---
# Defaults are fill-in placeholders kept literally in the email. Set your own to
# have them baked in instead.
LEADGEN_SENDER_NAME=[name]
LEADGEN_SENDER_COMPANY=[company]
LEADGEN_SENDER_EMAIL=[email]

# --- Storage ---
# LEADGEN_DATABASE_PATH=/opt/airflow/data/leads.db
